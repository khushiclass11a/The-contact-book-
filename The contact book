def contact_book():
    # Dictionary to store contacts: { "Name": ("Phone", "Label") }
    contacts = {}

    while True:
        print("\n--- Contact Book Menu ---")
        print("1. Add/Update Contact")
        print("2. Search Contact")
        print("3. View All")
        print("4. Exit")
        
        choice = input("Select an option (1-4): ")

        if choice == '1':
            name = input("Enter name: ").strip()
            phone = input("Enter phone number: ").strip()
            label = input("Enter label (Mobile/Work/Home): ").strip()
            
          
            contacts[name] = (phone, label)
            print(f"Contact '{name}' saved successfully.")

        elif choice == '2':
            search_name = input("Enter the name to search: ").strip()
          
            contact_info = contacts.get(search_name)
            
            if contact_info:
                phone, label = contact_info # Unpacking the tuple
                print(f"Found: {search_name} | Phone: {phone} ({label})")
            else:
                print("Contact not found.")

        elif choice == '3':
            if not contacts:
                print("The contact book is empty.")
            else:
                print("\n--- All Contacts ---")
                for name, info in contacts.items():
                    print(f"{name}: {info[0]} [{info[1]}]")

        elif choice == '4':
            print("Goodbye!")
            break
        else:
            print("Invalid choice, please try again.")

# Run the app
contact_book()
